   "source": [
    "import math\n",
    "\n",
    "def circle_area(radius):\n",
    "    area = math.pi * radius ** 2\n",
    "    return area\n",
    "\n",
    "# Input\n",
    "r = float(input(\"Enter radius: \"))\n",
    "\n",
    "# Output\n",
    "print(\"Area of circle:\", round(circle_area(r), 2))"
   ]
